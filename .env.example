# =============================================================================
# AI Teaching Platform - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your actual values
# Never commit .env.local to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase Configuration (Required)
# -----------------------------------------------------------------------------
# Get these from your Supabase project settings: https://app.supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# -----------------------------------------------------------------------------
# ElevenLabs Configuration (Required for Voice Features)
# -----------------------------------------------------------------------------
# Get your API key from: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here

# Optional: Override default voice settings
# ELEVENLABS_VOICE_ID=hpp4J3VqNfWAUOO0d1Us
# ELEVENLABS_MODEL_ID=eleven_flash_v2_5

# -----------------------------------------------------------------------------
# OpenRouter Configuration (Required for AI Models)
# -----------------------------------------------------------------------------
# Get your API key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Optional: Override default model settings
# OPENROUTER_MODEL=moonshotai/kimi-k2.5:nitro
# OPENROUTER_IMAGE_MODEL=google/gemini-2.5-flash-lite
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_HTTP_REFERER=https://your-domain.com
# OPENROUTER_APP_NAME=AI Teaching Platform

# -----------------------------------------------------------------------------
# Replicate Configuration (Required for Image Generation)
# -----------------------------------------------------------------------------
# Get your API token from: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=your-replicate-api-token-here

# Webhook secret for Replicate callbacks (must start with whsec_)
# Generate at: https://replicate.com/account/webhooks
REPLICATE_WEBHOOK_SECRET=whsec_your-webhook-secret-here

# -----------------------------------------------------------------------------
# Serper Configuration (Required for Image Search)
# -----------------------------------------------------------------------------
# Get your API key from: https://serper.dev/api-key
SERPER_API_KEY=your-serper-api-key-here

# -----------------------------------------------------------------------------
# Development Settings (Optional)
# -----------------------------------------------------------------------------
# NODE_ENV=development

# =============================================================================
# Service Overview
# =============================================================================
#
# ElevenLabs:
#   - Text-to-Speech (TTS) for teacher voice output
#   - Speech-to-Text (STT) with Scribe for learner voice input
#   - Model: Eleven Flash v2.5 (fastest, lowest latency)
#   - Voice: hpp4J3VqNfWAUOO0d1Us (default teacher voice)
#
# OpenRouter:
#   - Main tutor AI model: moonshotai/kimi-k2.5:nitro
#   - Image understanding: google/gemini-2.5-flash-lite
#   - Configurable routing for different AI providers
#
# Replicate:
#   - Background image generation using GPT-Image-2
#   - Quiz variant creation (label removal/swapping)
#   - Webhook-based async processing
#
# Serper:
#   - Google Images search for teaching visuals
#   - Teachability scoring and filtering
#
# Supabase:
#   - PostgreSQL database for lesson data
#   - Storage for media assets and canvas snapshots
#   - Authentication (optional for guest mode)
#   - Edge Functions for backend logic
#
# =============================================================================
# Required vs Optional
# =============================================================================
#
# REQUIRED (Core Functionality):
#   ✓ NEXT_PUBLIC_SUPABASE_URL
#   ✓ NEXT_PUBLIC_SUPABASE_ANON_KEY
#   ✓ SUPABASE_SERVICE_ROLE_KEY
#   ✓ OPENROUTER_API_KEY
#
# OPTIONAL (Enhanced Features):
#   • ELEVENLABS_API_KEY - Voice features (TTS + STT)
#   • REPLICATE_API_TOKEN - Background image generation
#   • REPLICATE_WEBHOOK_SECRET - Image generation webhooks
#   • SERPER_API_KEY - Image search
#
# Without optional keys, the platform runs in text-only mode with limited
# media capabilities.
#
# =============================================================================
